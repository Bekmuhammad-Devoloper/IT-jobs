# ============================================
# yuksalish.dev Production Environment (template)
# Copy this file to .env.production and fill values.
# NEVER commit .env.production — only this example.
# ============================================

# Database
POSTGRES_DB=yuksalish
POSTGRES_USER=postgres
DB_PASSWORD=<strong-random-password>

# Redis
REDIS_PASSWORD=<strong-random-password>

# JWT
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_EXPIRATION=7d

# Telegram Bot
BOT_TOKEN=<token-from-botfather>
CHANNEL_ID=<channel-id-like--100xxxxxxx>
CHANNEL_USERNAME=@your_channel

# Public URLs
WEBAPP_URL=https://your-domain
ADMIN_URL=https://your-domain/admin

# Admin
SUPER_ADMIN_IDS=<your-telegram-user-id>
ADMIN_SECRET_KEY=<random-secret>
ADMIN_USERNAME=<admin-login>
ADMIN_PASSWORD=<admin-password>

# Cron schedules (optional, defaults applied if omitted)
VIEWS_COLLECT_CRON=0 * * * *
RATING_CALC_CRON=0 0 * * *
CLEANUP_CRON=0 0 * * 0
POST_COOLDOWN_DAYS=15

# Gemini AI (Resume generator) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_API_KEY_2=<optional-fallback-key>

# Payment — card number + owner name shown on resume-order payment screen
PAYMENT_CARD=<your-card-number>
PAYMENT_OWNER=<card-owner-full-name>
